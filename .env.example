# ============================================================
# VPN Server Monitor — 环境变量配置
# 复制此文件为 .env 或通过 systemd Environment= 设置
# ============================================================

# 监听端口（默认 8088）
PORT=8088

# 监听地址（默认 0.0.0.0，仅本地访问设为 127.0.0.1）
HOST=0.0.0.0

# VPN 类型：auto（自动检测）/ singbox / wireguard / openvpn
VPN_TYPE=auto

# WireGuard 网卡名（仅在 WireGuard 模式下使用）
WG_INTERFACE=wg0

# OpenVPN 状态日志路径
OVPN_STATUS_LOG=/var/log/openvpn/openvpn-status.log

# sing-box 配置文件路径
SINGBOX_CONFIG=/etc/s-box/sb.json

# 数据采集间隔（秒）
NIC_SPEED_INTERVAL=2.0

# 可选：Token 鉴权（留空则不启用）
# 设置后，前端需通过 ?token=xxx 或 WebSocket ?token=xxx 访问
AUTH_TOKEN=
